{
    "name": "reward-loyalty/app",
    "type": "project",
    "description": "Enterprise Customer Loyalty Platform - Digital Savings Cards, Points, Stamps, Tiers & More",
    "keywords": [
        "loyalty",
        "rewards",
        "points",
        "stamps",
        "membership",
        "customer-engagement"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.363",
        "blade-ui-kit/blade-heroicons": "*",
        "blade-ui-kit/blade-icons": "*",
        "blade-ui-kit/blade-zondicons": "*",
        "codeat3/blade-phosphor-icons": "*",
        "commerceguys/intl": "*",
        "darkaonline/l5-swagger": "*",
        "doctrine/annotations": "^2.0",
        "ezyang/htmlpurifier": "*",
        "guzzlehttp/guzzle": "*",
        "intervention/image": "*",
        "laravel/framework": "*",
        "laravel/horizon": "*",
        "laravel/pennant": "*",
        "laravel/pulse": "*",
        "laravel/reverb": "*",
        "laravel/sanctum": "*",
        "laravel/socialite": "*",
        "laravel/tinker": "*",
        "laravolt/avatar": "*",
        "league/csv": "*",
        "league/flysystem-aws-s3-v3": "^3.30",
        "moneyphp/money": "*",
        "openai-php/client": "*",
        "pragmarx/google2fa-laravel": "*",
        "propaganistas/laravel-phone": "*",
        "resend/resend-laravel": "^1.0",
        "simplesoftwareio/simple-qrcode": "*",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-data": "*",
        "spatie/laravel-markdown": "*",
        "spatie/laravel-medialibrary": "*",
        "spatie/laravel-permission": "*",
        "spatie/laravel-sluggable": "*",
        "spatie/laravel-tags": "*",
        "spatie/laravel-translatable": "*",
        "spatie/laravel-webhook-client": "*",
        "spatie/laravel-webhook-server": "*",
        "symfony/http-client": "^7.0",
        "symfony/mailgun-mailer": "^7.0",
        "symfony/postmark-mailer": "^7.0",
        "twilio/sdk": "*",
        "vonage/client": "*"
    },
    "require-dev": {
        "fakerphp/faker": "*",
        "laravel/boost": "*",
        "laravel/pint": "*",
        "laravel/sail": "*",
        "mockery/mockery": "*",
        "nunomaduro/collision": "*",
        "pestphp/pest": "*",
        "pestphp/pest-plugin-laravel": "*",
        "spatie/laravel-ignition": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "echo Delete all unwanted files in vendor.",
            "find vendor -type d -name .git -exec rm -rf {} +"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "post-install-cmd": [
            "echo Delete all .git directories in vendor.",
            "find vendor -type d -name .git -exec rm -rf {} +"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
